# ─────────────────────────────────────────────────────────────────────────
# TVB-O — Clinical Applications addon
# Generated 2026-06-15 from a PubMed-verified survey of
# whole-brain / TVB dynamical-model applications to disease. Layer on top of
# tvb-o.owl (like tvb-o-axioms.ttl). Connects studies -> clinical domains
# (ICD-11 + MeSH) and -> the neural-mass model used.
# ─────────────────────────────────────────────────────────────────────────

@prefix tvbo:    <https://w3id.org/tvbo/> .
@prefix tvbc:    <https://w3id.org/tvbo/clinical/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix bibo:    <http://purl.org/ontology/bibo/> .
@prefix fabio:   <http://purl.org/spar/fabio/> .
@prefix MESH:    <http://purl.bioontology.org/ontology/MESH/> .
@prefix icd11:   <http://id.who.int/icd/release/11/mms/> .

### Vocabulary -----------------------------------------------------------
tvbc:ClinicalDomain a owl:Class ; rdfs:subClassOf skos:Concept ;
  rdfs:label "Clinical domain" ; rdfs:comment "A disease/condition area a model is applied to, cross-referenced to ICD-11 and MeSH." .
tvbc:ClinicalApplicationStudy a owl:Class ; rdfs:subClassOf bibo:AcademicArticle ;
  rdfs:label "Clinical application study" ; rdfs:comment "A publication applying a whole-brain / neural-mass model to patient data." .
tvbc:NodeDynamicsModel a owl:Class ; rdfs:subClassOf tvbo:Dynamics ;
  rdfs:label "Node dynamical model" ; rdfs:comment "Local node / mesoscale dynamics used in a whole-brain or microcircuit model: neural-mass and mean-field models (most align with tvbo:Dynamics), phenomenological oscillators (Hopf/Stuart-Landau), DCM convolution models, and spiking E/I networks." .
tvbc:appliesToClinicalDomain a owl:ObjectProperty ; rdfs:domain tvbc:ClinicalApplicationStudy ;
  rdfs:range tvbc:ClinicalDomain ; rdfs:label "applies to clinical domain" .
tvbc:hasClinicalApplication a owl:ObjectProperty ; owl:inverseOf tvbc:appliesToClinicalDomain ;
  rdfs:label "has clinical application" .
tvbc:usesNodeDynamics a owl:ObjectProperty ; rdfs:domain tvbc:ClinicalApplicationStudy ;
  rdfs:range tvbc:NodeDynamicsModel ; rdfs:label "uses node dynamical model" .
tvbc:studyKind a owl:DatatypeProperty ; rdfs:range xsd:string ; rdfs:label "study kind" .
tvbc:icd11Code a owl:AnnotationProperty ; rdfs:label "ICD-11 code" .

### ICD-11 chapters ------------------------------------------------------
tvbc:icd11-08 a skos:Concept ; skos:notation "08" ; skos:prefLabel "Diseases of the nervous system"@en .
tvbc:icd11-02 a skos:Concept ; skos:notation "02" ; skos:prefLabel "Neoplasms"@en .
tvbc:icd11-06 a skos:Concept ; skos:notation "06" ; skos:prefLabel "Mental, behavioural or neurodevelopmental disorders"@en .
tvbc:icd11-22 a skos:Concept ; skos:notation "22" ; skos:prefLabel "Injury, poisoning or external causes"@en .

### Node dynamical models ------------------------------------------------
tvbc:model-Epileptor a tvbc:NodeDynamicsModel ; skos:prefLabel "Epileptor"@en .
tvbc:model-ReducedWongWang a tvbc:NodeDynamicsModel ; skos:prefLabel "Reduced Wong-Wang / dynamic mean-field (Deco)"@en .
tvbc:model-JansenRit a tvbc:NodeDynamicsModel ; skos:prefLabel "Jansen-Rit"@en .
tvbc:model-Wendling a tvbc:NodeDynamicsModel ; skos:prefLabel "Wendling (Jansen-Rit-derived)"@en .
tvbc:model-StefanescuJirsa3D a tvbc:NodeDynamicsModel ; skos:prefLabel "Stefánescu-Jirsa 3D"@en .
tvbc:model-DodyNextGen a tvbc:NodeDynamicsModel ; skos:prefLabel "next-generation NMM (Montbrió/Dody, aQIF-derived)"@en .
tvbc:model-Hopf a tvbc:NodeDynamicsModel ; skos:prefLabel "Hopf / Stuart-Landau oscillator"@en .
tvbc:model-SpikingEI a tvbc:NodeDynamicsModel ; skos:prefLabel "Spiking E/I network (LIF)"@en .
tvbc:model-BasalGanglia a tvbc:NodeDynamicsModel ; skos:prefLabel "Basal-ganglia circuit model"@en .
tvbc:model-DynamicCausalModel a tvbc:NodeDynamicsModel ; skos:prefLabel "DCM canonical microcircuit"@en .

### Clinical domains (disease -> ICD-11 + MeSH) --------------------------
tvbc:domain-Epilepsy a tvbc:ClinicalDomain ;
  skos:prefLabel "Epilepsy"@en ;
  tvbc:icd11Code "8A6Z" ; skos:notation "8A6Z" ;
  skos:exactMatch MESH:D004827 ;   # Epilepsy
  skos:broader tvbc:icd11-08 ;
  skos:scopeNote "12 verified dynamical-model application(s) in TVB-O survey 2026" .
tvbc:domain-Alzheimer a tvbc:ClinicalDomain ;
  skos:prefLabel "Alzheimer disease & dementia"@en ;
  tvbc:icd11Code "8A20" ; skos:notation "8A20" ;
  skos:exactMatch MESH:D000544 ;   # Alzheimer Disease
  skos:broader tvbc:icd11-08 ;
  skos:scopeNote "11 verified dynamical-model application(s) in TVB-O survey 2026" .
tvbc:domain-Schizophrenia a tvbc:ClinicalDomain ;
  skos:prefLabel "Schizophrenia"@en ;
  tvbc:icd11Code "6A20" ; skos:notation "6A20" ;
  skos:exactMatch MESH:D012559 ;   # Schizophrenia
  skos:broader tvbc:icd11-06 ;
  skos:scopeNote "3 verified dynamical-model application(s) in TVB-O survey 2026" .
tvbc:domain-Parkinson a tvbc:ClinicalDomain ;
  skos:prefLabel "Parkinson disease"@en ;
  tvbc:icd11Code "8A00.0" ; skos:notation "8A00.0" ;
  skos:exactMatch MESH:D010300 ;   # Parkinson Disease
  skos:broader tvbc:icd11-08 ;
  skos:scopeNote "4 verified dynamical-model application(s) in TVB-O survey 2026" .
tvbc:domain-Stroke a tvbc:ClinicalDomain ;
  skos:prefLabel "Stroke"@en ;
  tvbc:icd11Code "8B20" ; skos:notation "8B20" ;
  skos:exactMatch MESH:D020521 ;   # Stroke
  skos:broader tvbc:icd11-08 ;
  skos:scopeNote "2 verified dynamical-model application(s) in TVB-O survey 2026" .
tvbc:domain-Tumour a tvbc:ClinicalDomain ;
  skos:prefLabel "Brain tumor / glioma"@en ;
  tvbc:icd11Code "2A00.0" ; skos:notation "2A00.0" ;
  skos:exactMatch MESH:D005910 ;   # Glioma
  skos:broader tvbc:icd11-02 ;
  skos:scopeNote "2 verified dynamical-model application(s) in TVB-O survey 2026" .
tvbc:domain-MS a tvbc:ClinicalDomain ;
  skos:prefLabel "Multiple sclerosis"@en ;
  tvbc:icd11Code "8A40" ; skos:notation "8A40" ;
  skos:exactMatch MESH:D009103 ;   # Multiple Sclerosis
  skos:broader tvbc:icd11-08 ;
  skos:scopeNote "1 verified dynamical-model application(s) in TVB-O survey 2026" .
tvbc:domain-TBI a tvbc:ClinicalDomain ;
  skos:prefLabel "Traumatic brain injury"@en ;
  tvbc:icd11Code "NA07" ; skos:notation "NA07" ;
  skos:exactMatch MESH:D000070642 ;   # Brain Injuries, Traumatic
  skos:broader tvbc:icd11-22 ;
  skos:scopeNote "1 verified dynamical-model application(s) in TVB-O survey 2026" .
tvbc:domain-DoC a tvbc:ClinicalDomain ;
  skos:prefLabel "Disorders of consciousness"@en ;
  tvbc:icd11Code "8E2Z" ; skos:notation "8E2Z" ;
  skos:exactMatch MESH:D003244 ;   # Consciousness Disorders
  skos:broader tvbc:icd11-08 ;
  skos:scopeNote "1 verified dynamical-model application(s) in TVB-O survey 2026" .
tvbc:domain-Depression a tvbc:ClinicalDomain ;
  skos:prefLabel "Major depressive disorder"@en ;
  tvbc:icd11Code "6A70" ; skos:notation "6A70" ;
  skos:exactMatch MESH:D003865 ;   # Depressive Disorder, Major
  skos:broader tvbc:icd11-06 ;
  skos:scopeNote "2 verified dynamical-model application(s) in TVB-O survey 2026" .
tvbc:domain-OCD a tvbc:ClinicalDomain ;
  skos:prefLabel "Obsessive-compulsive disorder"@en ;
  tvbc:icd11Code "6B20" ; skos:notation "6B20" ;
  skos:exactMatch MESH:D009771 ;   # Obsessive-Compulsive Disorder
  skos:broader tvbc:icd11-06 ;
  skos:scopeNote "1 verified dynamical-model application(s) in TVB-O survey 2026" .

