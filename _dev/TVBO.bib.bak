@Article{Chou2016,
  author    = {Chou, Richard C. and Kane, Michael and Ghimire, Sanjay and Gautam, Shiva and Gui, Jiang},
  journal   = {CNS Drugs},
  title     = {Treatment for Rheumatoid Arthritis and Risk of Alzheimer’s Disease: A Nested Case-Control Analysis},
  year      = {2016},
  issn      = {1179-1934},
  month     = jul,
  number    = {11},
  pages     = {1111--1120},
  volume    = {30},
  abstract  = {Introduction-It is increasingly becoming accepted that inflammation may play an important role in the pathogenesis of Alzheimer's disease (AD), as several immune-related genes have been associated with AD. Among these is tumor necrosis factor (TNF)-α, a proinflammatory cytokine known to play an important role in autoimmune disorders, including rheumatoid arthritis (RA). Although AD and RA appear to involve similar pathological mechanisms through the production of TNF-α, the relationship between AD and RA remains unknown. Objective-To determine the relative risk of AD among RA patients and non-RA patients, and whether anti-TNF therapy for RA was associated with a lower risk of AD in RA patients. Methods-We performed a nested case-control study of more than 8.5 million commercially insured adults (aged ≥18 years},
  date      = {2017-09-06},
  day       = {6},
  doi       = {10.1007/s40263-016-0374-z},
  file      = {:Chou2016 - Treatment for Rheumatoid Arthritis and Risk of Alzheimer’s Disease_ a Nested Case Control Analysis.pdf:PDF},
  publisher = {Springer Science and Business Media LLC},
}

@Article{Chtourou2011,
  author    = {Chtourou, H. and Chaouachi, A. and Hammouda, O. and Chamari, K. and Souissi, N.},
  journal   = {International Journal of Sports Medicine},
  title     = {Listening to Music Affects Diurnal Variation in Muscle Power Output},
  year      = {2011},
  issn      = {1439-3964},
  month     = dec,
  number    = {01},
  pages     = {43--47},
  volume    = {33},
  abstract  = {The fact that power during a 30-s Wingate test was lower in the morning raises the question of what limits performance at this time-of-day. In this context, since this test requires a strong level of motivation, Souissi et al. [ 18 ] suggested that the lower level of motivation in the morning could, in part, be responsible for such diurnal variation. Moreover, Lericollais et al. [ 13 ] suggested that a pacing-strategy eff ect (i. e., the strategies used by a subject to distribute work and energy throughout an exercise task) could also explain the lower performances observed in the morning. As the music′s motivational eff ects have been linked to increases in individual perceptions of self-esteem and sense of confi dence, enhancing arousal [ 11 ] and facilitating motor coordination [ 17 ] , the question then arises to determine if listening to music during warm-up can lead to similar or different improvements in short term exercise performances in the morning and evening. Thus, the aim of the present investigation was to study the diurnal fl uctuations during the Wingate test′s performance while examining if warm-up with music helps athletes to overcome the morning alteration of power output. The},
  date      = {2011-12-01},
  day       = {1},
  doi       = {10.1055/s-0031-1284398},
  file      = {:Chtourou2011 - Listening to Music Affects Diurnal Variation in Muscle Power Output.pdf:PDF},
  publisher = {Georg Thieme Verlag KG},
}

