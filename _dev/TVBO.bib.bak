@InProceedings{Habib2000,
  author    = {Habib, Michel and Demonet^, Francois},
  title     = {Dyslexia and Related Learning Disorders: Recent Advances from Brain Imaging Studies},
  year      = {2000},
  publisher = {ACADEMIC PRESS},
  abstract  = {During the past few years, dyslexia has been the focus of considerable interest from researchers in different scientific areas, for both theoretical and practical reasons. First, public awareness that this condition, which affects approximately 10% of the population, has a neurobiological basis gave rise to the hope of rational and effective therapy, which stimulated research in such different areas as neuropathology, neuropsychology, linguistics, and the educational sciences. As a consequence.},
