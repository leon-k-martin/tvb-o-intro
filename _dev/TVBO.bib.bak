@InProceedings{Beaulieu1896,
  author    = {Beaulieu, Christian and Bentley, Paul and Boly, Melanie and Brookes, Matthew and Calhoun, Vince and Chee, Michael and Cheng, Kang and Cohen, Michael and Daffertshofer, Andreas and Davatzikos, Christos and Debener, Stefan and Eichele, Tom and Eidelberg, David and Elliott, Rebecca and Ethofer, Thomas and Frackowiak, Richard and Gazzaley, Adam and Gee, James and Greenwood, Pamela and Grieve, Doug and Gross, Joachim and Gründer, Gerhard and Hyder, Fahmeed and Jbabdi, Saad and Kakigi, Ryusuke and Lanzenberger, Rupert and Lerch, Jason and Li, C and Li, Shu-Chen and Lowe, Mark and Mathiak, Klaus and Medendorp, Pieter and Menon, Vinod and Miller, Karla and Murphy, Kevin and Nichols, Thomas and Noppeney, Uta},
