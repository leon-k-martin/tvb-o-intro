@InProceedings{Nelson2020,
  author   = {Nelson, Peter and Alafuzoff, Irina and Bigio, Eileen and Bouras, Constantin and Braak, Heiko and Cairns, Nigel and Castellani, Rudolph and Crain, Barbara and Davies, Peter and Tredici, Kelly and Duyckaerts, Charles and Frosch, Matthew and Haroutunian, Vahram and Hof, Patrick and Hulette, Christine and Hyman, Bradley and Iwatsubo, Takeshi and Jellinger, Kurt and Jicha, Gregory and Kukull, Walter and Leverenz, James and Love, Seth and Mackenzie, Ian and Mann, David and Masliah, Eliezer and Mckee, Ann and Montine, Thomas and Morris, John and Schneider, Julie and Sonnen, Joshua and Thal, Dietmar and Trojanowski, John and Troncoso, Juan and Wisniewski, Thomas and Woltjer, Randall and Beach, Thomas},
  title    = {Correlation of Alzheimer Disease Neuropathologic Changes With Cognitive Status: A Review of the Literature},
  year     = {2020},
  month    = may,
  abstract = {Clinicopathologic correlation studies are critically important for the field of Alzheimer disease (AD) research. Studies on human subjects with autopsy confirmation entail numerous potential biases that affect both their general applicability and the validity of the correlations. Many sources of data variability can weaken the apparent correlation between cognitive status and AD neuropathologic changes. Indeed, most persons in advanced old age have significant non-AD brain lesions that may alter cognition independently of AD. Worldwide research efforts have evaluated thousands of human subjects to assess the causes of cognitive impairment in the elderly, and these studies have been interpreted in different ways. We review the literature focusing on the correlation of AD neuropathologic changes (i.e. A-amyloid plaques and neurofibrillary tangles) with cognitive impairment. We discuss the various patterns of brain changes that have been observed in elderly individuals to provide a perspective for understanding AD clinicopathologic correlation and conclude that From the Sanders-Brown Center on Aging (PTN, GAJ) and Departments of Pathology (PTN) and Neurology (GAJ),},
  date     = {2020-05-15},
  day      = {15},
  file     = {:Nelson2020 - Correlation of Alzheimer Disease Neuropathologic Changes with Cognitive Status_ a Review of the Literature.pdf:PDF},
  keywords = {Aging, Alzheimer disease, Amyloid, Dementia, Epidemiology, Neuropathology, MAPT, Neurofibrillary tangles},
}

