@Article{Harms2018,
  author    = {Harms, Michael P. and Somerville, Leah H. and Ances, Beau M. and Andersson, Jesper and Barch, Deanna M. and Bastiani, Matteo and Bookheimer, Susan Y. and Brown, Timothy B. and Buckner, Randy L. and Burgess, Gregory C. and Coalson, Timothy S. and Chappell, Michael A. and Dapretto, Mirella and Douaud, Gwenaëlle and Fischl, Bruce and Glasser, Matthew F. and Greve, Douglas N. and Hodge, Cynthia and Jamison, Keith W. and Jbabdi, Saad and Kandala, Sridhar and Li, Xiufeng and Mair, Ross W. and Mangia, Silvia and Marcus, Daniel and Mascali, Daniele and Moeller, Steen and Nichols, Thomas E. and Robinson, Emma C. and Salat, David H. and Smith, Stephen M. and Sotiropoulos, Stamatios N. and Terpstra, Melissa and Thomas, Kathleen M. and Tisdall, M. Dylan and Ugurbil, Kamil and van der Kouwe, Andre and Woods, Roger P. and Zöllei, Lilla and Van Essen, David C. and Yacoub, Essa},
