@InProceedings{Miller,
  author   = {Miller, Karla and Alfaro-Almagro, Fidel and Bangerter, Neal and Thomas, David and Yacoub, Essa and Xu, Junqian and Bartsch, Andreas and Jbabdi, Saad and Sotiropoulos, Stamatios and Andersson, Jesper and Griffanti, Ludovica and Douaud, Gwenaëlle and Okell, Thomas and Weale, Peter and Dragonu, Iulius and Garratt, Steve and Hudson, Sarah and Collins, Rory and Jenkinson, Mark and Matthews, Paul and Smith, Stephen},
  title    = {Multimodal population brain imaging in the UK Biobank prospective epidemiological study},
  abstract = {Medical imaging has enormous potential to provide early predictors of disease, yet has long been impeded by the difficulty and expense associated with acquiring datasets prior to symptom onset. UK Biobank aims to tackle this problem by conducting the largest population-level imaging study to date. High quality, consistently acquired imaging data will be collected from 100,000 participants, whose health outcomes will then be tracked over coming decades. Brain imaging in UK Biobank includes six structural, diffusion and functional modalities that, along with genetics, hundreds of lifestyle measures, biological phenotyping and health records, are expected to enable the discovery of imaging markers of a broad range of diseases at their earliest stages, as well as provide unique insight into disease mechanisms. We describe here the UK Biobank brain imaging study, and present results from the brain imaging data in the first open data release, comprising imaging data from around 5,000 participants. Although this covers just 5% of the ultimate imaging cohort, it already yields a rich range of associations between brain imaging and other measures collected by UK Biobank. These results presage a new era in brain imaging, in which complex phenotypic interactions can provide sensitive early markers of disease and aging.},
  file     = {:Miller - Multimodal Population Brain Imaging in the UK Biobank Prospective Epidemiological Study.pdf:PDF},
}

