  pages     = {iv},
  publisher = {Elsevier},
  title     = {Front cover photograph: Disorders of the human brai n can have a profound effect on its structur e and function. Mapping these disorder s not only improves the care and treatmen t of the individual patient but it also enables a greater understandin g of the anatomy and physiology of the normal , healthy human brai n and its failures when diseased. The cover design is intended to convey the devastation caused by disorder s of the brai n along with the promise of unlocking its mysteries. Cover produced by Arthur W. Toga; initial concept by John C. Mazziotta; graphics and renderin g by Rico Magsipoc; compositing by Andrew Lee},
  year      = {2000},
