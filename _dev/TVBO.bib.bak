  keywords = {1 lh-unknown L Unknown, 2 lh-bankssts L Banks of Superior Temporal Sulcus, 3 lh-caudalanteriorcingulate L Caudal Anterior Cingulate Frontal 4 lh-caudalmiddlefrontal L Caudal Middle Frontal Frontal},
