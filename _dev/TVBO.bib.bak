@InBook{Kaas2012,
  author    = {Kaas, Jon H.},
  pages     = {1074--1109},
  publisher = {Elsevier},
  title     = {Somatosensory System},
  year      = {2012},
  isbn      = {9780123742360},
  abstract  = {FIGURE 30. 1 The basic components of the somatosensory system shown on a posterolateral view of a human brain. Receptors in the skin project to the dorsal column nuclei or the trigeminal nuclei to form the dorsal column trigeminal complex. The trigeminal complex in the brainstem provide second-order afferents, representing the face, that join those from the dorsal column nuclei, representing the body, to terminate in the contralateral ventroposterior complex of the thalamus. Third-order neurons in the thalamus project to anterior parietal cortex, where information is distributed to posterior and lateral parietal cortex.},
  booktitle = {The Human Nervous System},
  doi       = {10.1016/b978-0-12-374236-0.10030-6},
  file      = {:Kaas2012 - Somatosensory System.pdf:PDF},
}

