@Article{Naze2025,
  author    = {Naze, Sebastien and Hearne, Luke J. and Sanz-Leon, Paula and Robinson, Conor and Hall, Caitlin V. and Sonkusare, Saurabh and Burgher, Bjorn and Zalesky, Andrew and Roberts, James A. and Cocchi, Luca},
  journal   = {Nature Communications},
  title     = {Mechanisms and interventions promoting healthy frontostriatal dynamics in obsessive-compulsive disorder},
  year      = {2025},
  issn      = {2041-1723},
  month     = aug,
  number    = {1},
  volume    = {16},
  abstract  = {Changes in the frontostriatal system activity support individuals' perseverance in distressful thoughts and rigid, repetitive behaviours that define obsessivecompulsive disorder (OCD). Converging evidence from preclinical and clinical work suggests that OCD maps onto a functional imbalance in the ventral and dorsal frontostriatal circuits. However, the neural mechanisms supporting these dysregulations remain elusive, their association with symptom severity is unclear, and therapeutic interventions are limited. To address these gaps, we combined neuroimaging and behavioural data from individuals with OCD and controls with computational modelling. We found that bidirectionally decreasing spontaneous neural coupling in the ventromedial circuit while concurrently increasing dorsolateral cortico-striatal coupling delivered the highest functional improvements in OCD. The analysis of longitudinal changes in obsessions and compulsions with respect to modelled neural interventions supported our predictions. By highlighting behaviourally meaningful neural mechanisms hidden from traditional neuroimaging analysis, this study advances knowledge on the neural basis of OCD and provides new therapeutic targets for obsessions and compulsions. 1234567890():,; 1234567890():,;},
  doi       = {10.1038/s41467-025-62190-2},
  file      = {:Naze2025 - Mechanisms and Interventions Promoting Healthy Frontostriatal Dynamics in Obsessive Compulsive Disorder.pdf:PDF},
  publisher = {Springer Science and Business Media LLC},
}

