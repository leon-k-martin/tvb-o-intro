@Article{Allen2012,
  author    = {Allen, Elena A. and Erhardt, Erik B. and Calhoun, Vince D.},
  journal   = {Neuron},
  title     = {Data Visualization in the Neurosciences: Overcoming the Curse of Dimensionality},
  year      = {2012},
  issn      = {0896-6273},
  month     = may,
  number    = {4},
  pages     = {603--608},
  volume    = {74},
  abstract  = {In publications, presentations, and popular media, scientific results are predominantly communicated through graphs. But are these figures clear and honest or misleading? We examine current practices in data visualization and discuss improvements, advocating design choices which reveal data rather than hide it.},
