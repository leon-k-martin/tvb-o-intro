@InProceedings{Braak1974,
  author   = {Braak},
  title    = {On the structure of the human archicortex},
  year     = {1974},
  abstract = {Braak Golgi technique we have not succeeded in discriminating the stratum oriens interneurons within pigment preparations. There are data available from the literature confirming the assumption that inhibitory interneurons of the cornu ammonis contain either 5-hydroxytryptamine or v-amino butyric acid or a related compound. The reasons for the idea that the pigment laden stellate cells possibly synthetize serotonin or a similar substance and the pigment lacking ones v-aminobutyric acid are discussed.},
  file     = {:Braak1974 - On the Structure of the Human Archicortex.pdf:PDF},
}

