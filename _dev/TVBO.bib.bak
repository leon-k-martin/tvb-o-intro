@Article{Menardi2022,
  author   = {Menardi A and Rossi S and Koch G and Hampel H and Vergallo A and Nitsche MA and Stern Y and Borroni B and Cappa SF and Cotelli M and Ruffini G and El-Fakhri G and Rossini PM and Dickerson B and Antal A and Babiloni C and Lefaucheur JP and Dubois B and Deco G and Ziemann U and Pascual-Leone A and Santarnecchi E},
