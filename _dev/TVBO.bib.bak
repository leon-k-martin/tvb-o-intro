@Article{Deistler2025,
  author    = {Deistler, Michael and Kadhim, Kyra L. and Pals, Matthijs and Beck, Jonas and Huang, Ziwei and Gloeckler, Manuel and Lappalainen, Janne K. and Schröder, Cornelius and Berens, Philipp and Gonçalves, Pedro J. and Macke, Jakob H.},
