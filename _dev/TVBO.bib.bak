@Article{Akiki2018,
  author    = {Akiki, Teddy J. and Averill, Christopher L. and Wrocklage, Kristen M. and Scott, J. Cobb and Averill, Lynnette A. and Schweinsburg, Brian and Alexander-Bloch, Aaron and Martini, Brenda and Southwick, Steven M. and Krystal, John H. and Abdallah, Chadi G.},
  journal   = {Data in Brief},
  title     = {Topology of brain functional connectivity networks in posttraumatic stress disorder},
  year      = {2018},
  issn      = {2352-3409},
  month     = oct,
  pages     = {1658--1675},
  volume    = {20},
  abstract  = {Here we present functional neuroimaging-based network data (focused on the default mode network) collected from a cohort of US Veterans with history of combat exposure, combined with clinical assessments for PTSD and other psychiatric comorbidities. The data has been processed and analyzed using several network construction methods (signed, thresholded, normalized to phaserandomized and rewired surrogates, functional and multimodal parcellation). An interpretation and discussion of the data can be found in the main NeuroImage article by Akiki et al.},
  date      = {2018-09-06},
  day       = {6},
  doi       = {10.1016/j.dib.2018.08.198},
  file      = {:Akiki2018 - Topology of Brain Functional Connectivity Networks in Posttraumatic Stress Disorder.pdf:PDF},
  keywords  = {fMRI, PTSD, Functional connectivity, Graph theory, Veterans, Intrinsic connectivity networks, Default mode network},
  publisher = {Elsevier BV},
}

