  groups    = {Neural Field Models},
  publisher = {Springer Science and Business Media LLC},
}

@InProceedings{Wilson1973a,
  author   = {Wilson, H and Cowan, J},
  title    = {A Mathematical Theory of the Functional Dynamics of Cortical and Thalamic Nervous Tissue},
  year     = {1973},
  abstract = {It is proposed that distinct anatomical regions of cerebral cortex and of thalamic nuclei are functionally two-dimensional. On this view, the third (radial) dimension of cortical and thalamic structures is associated with a redundancy of circuits and functions so that reliable signal processing obtains in the presence of noisy or ambiguous stimuli.},
  file     = {:Wilson1973a - A Mathematical Theory of the Functional Dynamics of Cortical and Thalamic Nervous Tissue.pdf:PDF},
}

@Article{Winkler2012,
  author    = {Winkler, Anderson M. and Sabuncu, Mert R. and Yeo, B.T. Thomas and Fischl, Bruce and Greve, Douglas N. and Kochunov, Peter and Nichols, Thomas E. and Blangero, John and Glahn, David C.},
  journal   = {NeuroImage},
  title     = {Measuring and comparing brain cortical surface area and other areal quantities},
  year      = {2012},
  issn      = {1053-8119},
  month     = jul,
  number    = {4},
  pages     = {1428--1443},
  volume    = {61},
  abstract  = {Structural analysis of MRI data on the cortical surface usually focuses on cortical thickness. Cortical surface area, when considered, has been measured only over gross regions or approached indirectly via comparisons with a standard brain. Here we demonstrate that direct measurement and comparison of the surface area of the cerebral cortex at a fine scale is possible using mass conservative interpolation methods. We present a framework for analyses of the cortical surface area, as well as for any other measurement distributed across the cortex that is areal by nature. The method consists of the construction of a mesh representation of the cortex, registration to a common coordinate system and, crucially, interpolation using a pycnophylactic method. Statistical analysis of surface area is done with power-transformed data to address lognormality, and inference is done with permutation methods. We introduce the concept of facewise analysis, discuss its interpretation and potential applications.},
  date      = {2012-03-15},
  day       = {15},
  doi       = {10.1016/j.neuroimage.2012.03.026},
  file      = {:Winkler2012 - Measuring and Comparing Brain Cortical Surface Area and Other Areal Quantities.pdf:PDF},
  keywords  = {Brain surface area Facewise analysis Areal interpolation Pycnophylactic interpolation Structural analysis of MRI data on the cortical surface usually focuses on cortical thickness. Cortical surface area, when considered, has been measured only over gross regions or approached indirectly via comparisons with a standard brain. Here we demonstrate that direct measurement and comparison of the surface area of the cerebral cortex at a fine scale is possible using mass conservative interpolation methods. We present a framework for analyses of the cortical surface area, as well as for any other measurement distributed across the cortex that is areal by nature. The method consists of the construction of a mesh representation of the cortex, registration to a common coordinate system and, crucially, interpolation using a pycnophylactic method. Statistical analysis of surface area is done with power-transformed data to address lognormality, and inference is done with permutation methods. We introduce the concept of facewise analysis, discuss its interpretation and potential applications},
  publisher = {Elsevier BV},
}

