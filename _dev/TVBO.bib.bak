  pmid     = {31292816},
}

@Article{Bennett2010,
  author    = {Bennett, Craig M. and Miller, Michael B.},
  journal   = {Annals of the New York Academy of Sciences},
  title     = {How reliable are the results from functional magnetic resonance imaging?},
  year      = {2010},
  issn      = {1749-6632},
  month     = mar,
  number    = {1},
  pages     = {133--155},
  volume    = {1191},
  abstract  = {Functional magnetic resonance imaging (fMRI) is one of the most important methods for in vivo investigation of cognitive processes in the human brain. Within the last two decades, an explosion of research has emerged using fMRI, revealing the underpinnings of everything from motor and sensory processes to the foundations of social cognition. While these results have revealed the potential of neuroimaging, important questions regarding the reliability of these results remain unanswered. In this paper, we take a close look at what is currently known about the reliability of fMRI findings. First, we examine the many factors that influence the quality of acquired fMRI data. We also conduct a review of the existing literature to determine if some measure of agreement has emerged regarding the reliability of fMRI. Finally, we provide commentary on ways to improve fMRI reliability and what questions remain unanswered. Reliability is the foundation on which scientific investigation is based. How reliable are the results from fMRI?},
  doi       = {10.1111/j.1749-6632.2010.05446.x},
  file      = {:Bennett2010 - How Reliable Are the Results from Functional Magnetic Resonance Imaging_.pdf:PDF},
  keywords  = {fMRI, statistics, reliability},
  publisher = {Wiley},
}

@InProceedings{Bennett2021,
  author = {Bennett, Daniel and Silverstein, Steven and Niv, Yael},
  title  = {Opinion},
  year   = {2021},
  file   = {:Bennett2021 - Opinion.pdf:PDF},
}

@Article{BenoitCattin2005,
  author    = {Benoit-Cattin, H. and Collewet, G. and Belaroussi, B. and Saint-Jalmes, H. and Odet, C.},
  journal   = {Journal of Magnetic Resonance},
  title     = {The SIMRI project: a versatile and interactive MRI simulator},
  year      = {2005},
  issn      = {1090-7807},
  month     = mar,
  number    = {1},
  pages     = {97--115},
  volume    = {173},
  abstract  = {This paper gives an overview of SIMRI, a new 3D MRI simulator based on the Bloch equation. This simulator proposes an efficient management of the T Ã 2 effect, and in a unique simulator integrates most of the simulation features that are offered in different simulators. It takes into account the main static field value and enables realistic simulations of the chemical shift artifact, including off-resonance phenomena. It also simulates the artifacts linked to the static field inhomogeneity like those induced by susceptibility variation within an object. It is implemented in the C language and the MRI sequence programming is done using high level C functions with a simple programming interface. To manage large simulations, the magnetization kernel is implemented in a parallelized way that enables simulation on PC grid architecture. Furthermore, this simulator includes a 1D interactive interface for pedagogic purpose illustrating the magnetization vector motion as well as the MRI contrasts.},
  date      = {2004-12-22},
  day       = {22},
  doi       = {10.1016/j.jmr.2004.09.027},
  file      = {:BenoitCattin2005 - The SIMRI Project_ a Versatile and Interactive MRI Simulator.pdf:PDF},
  keywords  = {MRI simulation, Bloch equation, Artefacts, Field inhomogeneity, Software},
