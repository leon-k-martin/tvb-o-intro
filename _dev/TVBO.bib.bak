@Article{Poldrack2011,
  author    = {Poldrack, Russell A. and Kittur, Aniket and Kalar, Donald and Miller, Eric and Seppa, Christian and Gil, Yolanda and Parker, D. Stott and Sabb, Fred W. and Bilder, Robert M.},
