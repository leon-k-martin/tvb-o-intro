@Article{Boulant2024,
  author    = {Boulant, Nicolas and Mauconduit, Franck and Gras, Vincent and Amadon, Alexis and Le Ster, Caroline and Luong, Michel and Massire, Aurélien and Pallier, Christophe and Sabatier, Laure and Bottlaender, Michel and Vignaud, Alexandre and Le Bihan, Denis},
