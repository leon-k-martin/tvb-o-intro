@Article{Giorgi2020,
  author    = {Giorgi, Filippo Sean and Saccaro, Luigi Francesco and Busceti, Carla Letizia and Biagioni, Francesca and Fornai, Francesco},
  journal   = {Brain Research Bulletin},
  title     = {Epilepsy and Alzheimer’s Disease: Potential mechanisms for an association},
  year      = {2020},
  issn      = {0361-9230},
  month     = jul,
  pages     = {107--120},
  volume    = {160},
  abstract  = {Alzheimer's Disease (AD) and epilepsy are common neurological diseases. The prevalence of epilepsy in AD patients is higher than in healthy subjects, but identifying the reasons for this association, the characteristics of seizures in AD, and the implications for prognosis and treatment is challenging. The present review provides first of all an overview of the main clinical aspects of AD and epilepsy, of their reciprocal relationship, and of the challenges that identifying seizures in AD patients presents. Limitations of clinical studies addressing this topic are discussed, including their mostly prospective nature and possible selection biases. A comprehensive, mechanistic discussion on the factors that are most likely to underlie the increased risk for seizures in AD follows. These include, for instance, GABAergic and glutamatergic alterations, Aβ and Tau protein, the role of the noradrenergic nucleus Locus Coeruleus, and neuroinflammation. Finally, evidence concerning the role that epilepsy may have in exacerbating or initiating AD is reviewed. A mechanistic insight on the relationship between epilepsy and AD might have relevant implications for improving the treatment of AD patients, as well as in elucidating pathophysiological mechanisms.},
  date      = {2020-05-05},
  day       = {5},
  doi       = {10.1016/j.brainresbull.2020.04.009},
  file      = {:Giorgi2020 - Epilepsy and Alzheimer’s Disease_ Potential Mechanisms for an Association.pdf:PDF},
  keywords  = {Epilepsy Alzheimer's Disease Neuroinflammation Locus Coeruleus Acetylcholine Amyloid AD, Alzheimer's Disease, (f)Aβ, (fibrillary) β-amyloid, AED, antiepileptic drugs, AMPA-R, α-amino-3-hydroxy-5-methyl-4-isoxazolepropionic acid receptor, APP, Amyloid Precursor Protein, BACE, beta-secretase, BBB, blood-brain barrier, CCL, chemokine ligand, CD, cluster of differentiation, CNS, central nervous system, COX, cyclooxygenase, CR-3, complement receptor-3, CSF, cerebrospinal fluid, DAMP, damage-associated molecular patterns, DC, dendritic cells, DSP-4, N-(2chloroethyl)-N-ethyl-2-bromobenzylamine hydrochloride, EAAT, excitatory amino acid transporter, EEG, electroencephalogram, EOAD, Early Onset Alzheimer Disease, fMRI, Functional Magnetic Resonance Imaging, FMRP, fragile X mental retardation protein, GABA, γ-aminobutyric acid, GFAP, glial fibrillary acidic protein, hAPP, human Amyloid Precursor Protein, IED, Interictal Epileptic Discharge, IL, interleukin, iNOS, inducible-Nitric Oxide Synthase, KCNQ, Potassium Channel, Voltage-Gated, KQT-like subfamily, LC, Locus Coeruleus, LTD, Long Term Depression, LTP, Long Term Potentiation, MCI, Mild Cognitive Impairment, mGluR5, metabotropic glutamate receptor 5, MMSE, Mini-Mental State Examination, MTLE, mesial temporal lobe epilepsy, NaV, voltage-gated sodium channel, n-Ach-R, nicotinic acetylcholine receptors, NE, Norepinephrine, NFT, neurofibrillary tangles, NMDA-R, N-methyl-D-aspartate-receptor, PET, positron emission tomography, Prp c , cellular prion protein C, PS, presenilin, TNF, tumor necrosis factor},
  publisher = {Elsevier BV},
}

