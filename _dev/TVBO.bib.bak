@Article{Dumitrescu2019,
  author    = {Dumitrescu, Logan and Barnes, Lisa L and Thambisetty, Madhav and Beecham, Gary and Kunkle, Brian and Bush, William S and Gifford, Katherine A and Chibnik, Lori B and Mukherjee, Shubhabrata and De Jager, Philip L and Kukull, Walter and Crane, Paul K and Resnick, Susan M and Keene, C Dirk and Montine, Thomas J and Schellenberg, Gerard D and Deming, Yuetiva and Chao, Michael J and Huentelman, Matt and Martin, Eden R and Hamilton-Nelson, Kara and Shaw, Leslie M and Trojanowski, John Q and Peskind, Elaine R and Cruchaga, Carlos and Pericak-Vance, Margaret A and Goate, Alison M and Cox, Nancy J and Haines, Jonathan L and Zetterberg, Henrik and Blennow, Kaj and Larson, Eric B and Johnson, Sterling C and Albert, Marilyn and Bennett, David A and Schneider, Julie A and Jefferson, Angela L and Hohman, Timothy J},
  journal   = {Brain},
  title     = {Sex differences in the genetic predictors of Alzheimer’s pathology},
  year      = {2019},
  issn      = {1460-2156},
  month     = jul,
  number    = {9},
  pages     = {2581--2589},
  volume    = {142},
  abstract  = {/ADNI_Acknowledgement_List.pdf Autopsy measures of Alzheimer's disease neuropathology have been leveraged as endophenotypes in previous genome-wide association studies (GWAS). However, despite evidence of sex differences in Alzheimer's disease risk, sex-stratified models have not been incorporated into previous GWAS analyses. We looked for sex-specific genetic associations with Alzheimer's disease endophenotypes from six brain bank data repositories. The pooled dataset included 2701 males and 3275 females, the majority of whom were diagnosed with Alzheimer's disease at autopsy (70%). Sex-stratified GWAS were performed within each dataset and then meta-analysed. Loci that reached genome-wide significance (P 5 5 Â 10 À8) in stratified models were further assessed for sex interactions. Additional analyses were performed in independent datasets leveraging cognitive, neuroimaging and CSF endophenotypes, along with age-at-onset data. Outside of the APOE region, one locus on chromosome 7 (rs34331204) showed a sexspecific association with neurofibrillary tangles among males (P = 2.5 Â 10 À8) but not females (P = 0.85, sex-interaction P = 2.9 Â 10 À4). In follow-up analyses, rs34331204 was also associated with hippocampal volume, executive function, and ageat-onset only among males. These results implicate a novel locus that confers male-specific protection from tau pathology and highlight the value of assessing genetic associations in a sex-specific manner.},
  date      = {2019-07-20},
  day       = {20},
  doi       = {10.1093/brain/awz206},
  file      = {:Dumitrescu2019 - Sex Differences in the Genetic Predictors of Alzheimer’s Pathology.pdf:PDF},
  keywords  = {Alzheimer's disease, neuropathology, beta-amyloid, tau, genome-wide association study},
  publisher = {Oxford University Press (OUP)},
}

