  year      = {2018},
  issn      = {1053-8119},
  month     = dec,
  pages     = {972--984},
  volume    = {183},
  abstract  = {The Human Connectome Projects in Development (HCP-D) and Aging (HCP-A) are two large-scale brain imaging studies that will extend the recently completed HCP Young-Adult (HCP-YA) project to nearly the full lifespan, collecting structural, resting-state fMRI, task-fMRI, diffusion, and perfusion MRI in participants from 5 to 100þ years of age. HCP-D is enrolling 1300þ healthy children, adolescents, and young adults (ages 5-21), and},
  date      = {2018-09-24},
