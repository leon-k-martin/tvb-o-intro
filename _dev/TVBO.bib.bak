  author = {The, Gene and Consortium and Ashburner, Michael and Ball, Catherine and Blake, Judith and Botstein, David and Butler, Heather and Cherry, J and Davis, Allan and Dolinski, Kara and Dwight, Selina and Eppig, Janan and Harris, Midori and Hill, David and Issel-Tarver, Laurie and Kasarskis, Andrew and Lewis, Suzanna and Matese, John and Richardson, Joel and Ringwald, Martin and Rubin, Gerald and Sherlock, Gavin},
