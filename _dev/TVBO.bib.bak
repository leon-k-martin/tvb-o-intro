@Article{Honig2018,
  author    = {Honig, Lawrence S. and Vellas, Bruno and Woodward, Michael and Boada, Mercè and Bullock, Roger and Borrie, Michael and Hager, Klaus and Andreasen, Niels and Scarpini, Elio and Liu-Seifert, Hong and Case, Michael and Dean, Robert A. and Hake, Ann and Sundell, Karen and Poole Hoffmann, Vicki and Carlson, Christopher and Khanna, Rashna and Mintun, Mark and DeMattos, Ronald and Selzler, Katherine J. and Siemers, Eric},
