@Article{Zimmermann2018,
  author    = {Zimmermann, J and Perry, A and Breakspear, M and Schirner, M and Sachdev, P and Wen, W and Kochan, N.A. and Mapstone, M. and Ritter, P. and McIntosh, A.R. and Solodkin, A},
  title     = {Differentiation of Alzheimer’s disease based on local and global parameters in personalized Virtual Brain models},
  year      = {2018},
  month     = mar,
  doi       = {10.1101/277624},
  publisher = {Cold Spring Harbor Laboratory},
}

@Article{Zimmermann2018a,
  author    = {Zimmermann, J. and Perry, A. and Breakspear, M. and Schirner, M. and Sachdev, P. and Wen, W. and Kochan, N.A. and Mapstone, M. and Ritter, P. and McIntosh, A.R. and Solodkin, A.},
  journal   = {NeuroImage: Clinical},
  title     = {Differentiation of Alzheimer’s disease based on local and global parameters in personalized Virtual Brain models},
  year      = {2018},
  issn      = {2213-1582},
  month     = apr,
  pages     = {240--251},
  volume    = {19},
  abstract  = {Alzheimer's disease (AD) is marked by cognitive dysfunction emerging from neuropathological processes impacting brain function. AD affects brain dynamics at the local level, such as changes in the balance of inhibitory and excitatory neuronal populations, as well as long-range changes to the global network. Individual differences in these changes as they relate to behaviour are poorly understood. Here, we use a multi-scale neurophysiological model, "The Virtual Brain (TVB)", based on empirical multi-modal neuroimaging data, to study how local and global dynamics correlate with individual differences in cognition. In particular, we modeled individual resting-state functional activity of 124 individuals across the behavioural spectrum from healthy aging, to amnesic Mild Cognitive Impairment (MCI), to AD. The model parameters required to accurately simulate empirical functional brain imaging data correlated significantly with cognition, and exceeded the predictive capacity of empirical connectomes.},
  date      = {2018-04-20},
  day       = {20},
  doi       = {10.1016/j.nicl.2018.04.017},
  file      = {:Zimmermann2018a - Differentiation of Alzheimer’s Disease Based on Local and Global Parameters in Personalized Virtual Brain Models.pdf:PDF},
  groups    = {Alzheimer, Annotate!},
  publisher = {Elsevier BV},
}

