@InProceedings{Alger3050,
  author    = {Alger, Jeffry and Mcl Black, Peter and Cannestr, Andrew and Cloughesy, Timothy and Departmen T Of Neurology, ) and Singleton Brain, Henry and Cummings, Jeffrey and Departmen T Of Psychiatr, ) and Sciences, Biobehaviora and Demonet, Jean-Francois and Dolan, R and Duncan, John and Edwards, C and Eidelberg, D and Fletcher, P and Frackowiak, Richard and Friston, Karl and Frith, Chris and Gering, David and Grafton, Scott and Grimson, Eric and Habib, Michel and Hallett, Marl< and Hata, Nobuhiko and Henry, Thomas and Heumann, Mary and Jolesz, Ferenc and Junck, Larry and Kikinis, Ron and Li, David and Marchal, G and Mayberg, Helen and Mazziotta, John and Moeller, J and Ojemann, George and Ojemann, Jeffrey and Pergolizzi, Richard and Price, Cathy and Departmen, Wellcome and Neurology, Cognitive and Schwart, Richard},
