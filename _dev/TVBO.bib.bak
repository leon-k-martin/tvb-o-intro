@Article{Baldock2005,
  author    = {Baldock, Richard and Burger, Albert},
  journal   = {Genome Biology},
  title     = {Anatomical ontologies: names and places in biology},
  year      = {2005},
  issn      = {1465-6906},
  month     = mar,
  number    = {4},
  pages     = {108},
  volume    = {6},
  abstract  = {Ontology has long been the preserve of philosophers and logicians. Recently, ideas from this field have been picked up by computer scientists as a basis for encoding knowledge and with the hope of achieving interoperability and intelligent system behavior. In bioinformatics, ontologies might allow hitherto impossible query and data-mining activities. We review the use of anatomy ontologies to represent space in biological organisms, specifically mouse and human.},
  date      = {2005-03-15},
  day       = {15},
  doi       = {10.1186/gb-2005-6-4-108},
  file      = {:Baldock2005 - Anatomical Ontologies_ Names and Places in Biology.pdf:PDF},
  publisher = {Springer Science and Business Media LLC},
}

