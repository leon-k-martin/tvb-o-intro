  title     = {The Alzheimer’s Disease Neuroimaging Initiative: Progress report and future plans},
  year      = {2010},
  issn      = {1552-5279},
  month     = may,
  number    = {3},
  pages     = {202},
  volume    = {6},
  abstract  = {The Alzheimer's Disease Neuroimaging Initiative (ADNI) beginning in October 2004, is a 6-year research project that studies changes of cognition, function, brain structure and function, and biomarkers in elderly controls, subjects with mild cognitive impairment, and subjects with Alzheimer's disease (AD). A major goal is to determine and validate MRI, PET images, and cerebrospinal fluid (CSF)/blood biomarkers as predictors and outcomes for use in clinical trials of},
  date      = {2010-08-24},
  day       = {24},
  doi       = {10.1016/j.jalz.2010.03.007},
  file      = {:Weiner2010 - The Alzheimer’s Disease Neuroimaging Initiative_ Progress Report and Future Plans.pdf:PDF},
  keywords  = {ADNI, Alzheimer's disease, MRI, PET, Amyloid, Memory, Tau},
  publisher = {Wiley},
}

@Article{Weiner2011,
  author    = {Weiner, Michael W. and Veitch, Dallas P. and Aisen, Paul S. and Beckett, Laurel A. and Cairns, Nigel J. and Green, Robert C. and Harvey, Danielle and Jack, Clifford R. and Jagust, William and Liu, Enchi and Morris, John C. and Petersen, Ronald C. and Saykin, Andrew J. and Schmidt, Mark E. and Shaw, Leslie and Siuciak, Judith A. and Soares, Holly and Toga, Arthur W. and Trojanowski, John Q.},
  journal   = {Alzheimer’s &amp; Dementia},
  title     = {The Alzheimer’s Disease Neuroimaging Initiative: A review of papers published since its inception},
  year      = {2011},
  issn      = {1552-5279},
  month     = nov,
  number    = {1S},
  volume    = {8},
  abstract  = {The Alzheimer's Disease Neuroimaging Initiative (ADNI) is an ongoing, longitudinal, multicenter study designed to develop clinical, imaging, genetic and biochemical biomarkers for the early detection and tracking of Alzheimer's disease (AD). The study aimed to enroll 400 subjects with early mild cognitive impairment (MCI), 200 subjects with early AD and 200 normal controls and},
  date      = {2013-02-01},
