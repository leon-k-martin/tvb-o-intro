@Article{Liu2019,
  author    = {Liu, Jinping and Chang, Lirong and Song, Yizhi and Li, Hui and Wu, Yan},
  journal   = {Frontiers in Neuroscience},
  title     = {The Role of NMDA Receptors in Alzheimer’s Disease},
  year      = {2019},
  issn      = {1662-453X},
  month     = feb,
  volume    = {13},
  abstract  = {In Alzheimer's disease (AD), early synaptic dysfunction is associated with the increased oligomeric amyloid-beta peptide, which causes NMDAR-dependent synaptic depression and spine elimination. Memantine, low-affinity NMDAR channel blocker, has been used in the treatment of moderate to severe AD. However, clear evidence is still deficient in demonstrating the underlying mechanisms and a relationship between NMDARs dysfunction and AD. This review focuses on not only changes in expression of different NMDAR subunits, but also some unconventional modes of NMDAR action.},
  date      = {2019-02-08},
  day       = {8},
  doi       = {10.3389/fnins.2019.00043},
  editor    = {Tai Wai Yew, Roland Brandt,},
  file      = {:Liu2019 - The Role of NMDA Receptors in Alzheimer’s Disease.pdf:PDF},
  keywords  = {NMDA receptor, amyloid beta, memantine, Alzheimer's disease, synaptic dysfunction},
  publisher = {Frontiers Media SA},
  source    = {fnins-13-00043.tex},
}

