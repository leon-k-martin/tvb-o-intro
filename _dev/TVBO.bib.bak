@Article{Quattrone2021,
  author    = {Quattrone, Diego and Reininghaus, Ulrich and Richards, Alex L. and Tripoli, Giada and Ferraro, Laura and Quattrone, Andrea and Marino, Paolo and Rodriguez, Victoria and Spinazzola, Edoardo and Gayer-Anderson, Charlotte and Jongsma, Hannah E. and Jones, Peter B. and La Cascia, Caterina and La Barbera, Daniele and Tarricone, Ilaria and Bonora, Elena and Tosato, Sarah and Lasalvia, Antonio and Szöke, Andrei and Arango, Celso and Bernardo, Miquel and Bobes, Julio and Del Ben, Cristina Marta and Menezes, Paulo Rossi and Llorca, Pierre-Michel and Santos, Jose Luis and Sanjuán, Julio and Arrojo, Manuel and Tortelli, Andrea and Velthorst, Eva and Berendsen, Steven and de Haan, Lieuwe and Rutten, Bart P. F. and Lynskey, Michael T. and Freeman, Tom P. and Kirkbride, James B. and Sham, Pak C. and O’Donovan, Michael C. and Cardno, Alastair G. and Vassos, Evangelos and van Os, Jim and Morgan, Craig and Murray, Robin M. and Lewis, Cathryn M. and Di Forti, Marta and Hubbard, Kathryn and Beards, Stephanie and Stilo, Simona A. and Parellada, Mara and Fraguas, David and Castro, Marta Rapado and Andreu-Bernabeu, Álvaro and López, Gonzalo and Matteis, Mario and González, Emiliano and Durán-Cutilla, Manuel and Díaz-Caneja, Covadonga M. and Cuadrado, Pedro and Rodríguez Solano, José Juan and Carracedo, Angel and Costas, Javier and Sánchez, Emilio and Amoretti, Silvia and Lorente-Rovira, Esther and Garcia-Portilla, Paz and Jiménez-López, Estela and Franke, Nathalie and van Dam, Daniella and Termorshuizen, Fabian and Franke, Nathalie and van der Ven, Elsje and Messchaart, Elles and Leboyer, Marion and Schürhoff, Franck and Jamain, Stéphane and Baudin, Grégoire and Ferchiou, Aziz and Pignon, Baptiste and Richard, Jean-Romain and Charpeaud, Thomas and Tronche, Anne-Marie and Frijda, Flora and Marrazzo, Giovanna and Sideli, Lucia and Sartorio, Crocettarachele and Seminerio, Fabio and Loureiro, Camila Marcelino and Shuhama, Rosana and Ruggeri, Mirella and Bonetto, Chiara and Cristofalo, Doriana and Berardi, Domenico and Seri, Marco and D’Andrea, Giuseppe},
  journal   = {Translational Psychiatry},
  title     = {The continuity of effect of schizophrenia polygenic risk score and patterns of cannabis use on transdiagnostic symptom dimensions at first-episode psychosis: findings from the EU-GEI study},
  year      = {2021},
  issn      = {2158-3188},
  month     = aug,
  number    = {1},
  volume    = {11},
  abstract  = {Diagnostic categories do not completely reflect the heterogeneous expression of psychosis. Using data from the EU-GEI study, we evaluated the impact of schizophrenia polygenic risk score (SZ-PRS) and patterns of cannabis use on the transdiagnostic expression of psychosis. We analysed first-episode psychosis patients (FEP) and controls, generating transdiagnostic dimensions of psychotic symptoms and experiences using item response bi-factor modelling. Linear regression was used to test the associations between these dimensions and SZ-PRS, as well as the combined effect of SZ-PRS and cannabis use on the dimensions of positive psychotic symptoms and experiences. We found associations between SZ-PRS and (1) both negative (B = 0.18; 95%CI 0.03-0.33) and positive (B = 0.19; 95%CI 0.03-0.35) symptom dimensions in 617 FEP patients, regardless of their categorical diagnosis; and (2) all the psychotic experience dimensions in 979 controls. We did not observe associations between SZ-PRS and the general and affective dimensions in FEP. Daily and current cannabis use were associated with the positive dimensions in FEP (B = 0.31; 95%CI 0.11-0.52) and in controls (B = 0.26; 95%CI 0.06-0.46), over and above SZ-PRS. We provide evidence that genetic liability to schizophrenia and cannabis use map onto transdiagnostic symptom dimensions, supporting the validity and utility of the dimensional representation of psychosis. In our sample, genetic liability to schizophrenia correlated with more severe psychosis presentation, and cannabis use conferred risk to positive symptomatology beyond the genetic risk. Our findings support the hypothesis that psychotic experiences in the general population have similar genetic substrates as clinical disorders.},
  doi       = {10.1038/s41398-021-01526-0},
  file      = {:Quattrone2021 - The Continuity of Effect of Schizophrenia Polygenic Risk Score and Patterns of Cannabis Use on Transdiagnostic Symptom Dimensions at First Episode Psychosis_ Findings from the EU GEI Study.pdf:PDF},
  publisher = {Springer Science and Business Media LLC},
}

