@Article{Passingham2013,
  author    = {Passingham, Richard E.},
  journal   = {NeuroImage},
  title     = {What we can and cannot tell about the wiring of the human brain},
  year      = {2013},
  issn      = {1053-8119},
  month     = oct,
  pages     = {14--17},
  volume    = {80},
  abstract  = {It was 20 years ago that Crick and Jones lamented the fact that human neuroanatomy was backward. They would be astonished to read the contents of this issue. At that time they had not foreseen what could be achieved by the combination of diffusion imaging and the study of resting state covariance. This paper assesses what can and cannot be done with the methods that we now have.},
  date      = {2013-01-13},
  day       = {13},
  doi       = {10.1016/j.neuroimage.2013.01.010},
  file      = {:Passingham2013 - What We Can and Cannot Tell about the Wiring of the Human Brain.pdf:PDF},
  publisher = {Elsevier BV},
}

@Article{Patel2012,
  author    = {Patel, Aniruddh D.},
  journal   = {Annals of the New York Academy of Sciences},
  title     = {The OPERA hypothesis: assumptions and clarifications},
  year      = {2012},
  issn      = {1749-6632},
  month     = apr,
  number    = {1},
  pages     = {124--128},
  volume    = {1252},
  abstract  = {Recent research suggests that musical training enhances the neural encoding of speech. Why would musical training have this effect? The OPERA hypothesis proposes an answer on the basis of the idea that musical training demands greater precision in certain aspects of auditory processing than does ordinary speech perception. This paper presents two assumptions underlying this idea, as well as two clarifications, and suggests directions for future research.},
  doi       = {10.1111/j.1749-6632.2011.06426.x},
  file      = {:Patel2012 - The OPERA Hypothesis_ Assumptions and Clarifications.pdf:PDF},
  keywords  = {musical training, speech perception, neural plasticity, neural encoding, pitch perception},
  publisher = {Wiley},
}

