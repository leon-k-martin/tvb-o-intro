  author = {Williams, Kate and Berthelsen, Donna and Ba, M and Apppsych and Nicholson, Jan and Walker, Sue and Abad, Vicky},
  title  = {The Effectiveness of a Short-Term Group Music Therapy Intervention for Parents Who Have a Child with a Disability},
  year   = {2012},
