@Article{Khatami2020,
  author    = {Khatami, Sepehr Golriz and Mubeen, Sarah and Bharadhwaj, Vinay Srinivas and Kodamullil, Alpha Tom and Hofmann-Apitius, Martin and Domingo-Fernández, Daniel},
  title     = {Using predictive machine learning models for drug response simulation by calibrating patient-specific pathway signatures},
  year      = {2020},
  month     = dec,
  abstract  = {The utility of pathway signatures lies in their capability to determine whether a specific pathway or biological process is dysregulated in a given patient. These signatures have been widely used in machine learning (ML) methods for a variety of applications including precision medicine, drug repurposing, and drug discovery. In this work, we leverage highly predictive ML models for drug response simulation in individual patients by calibrating the pathway activity scores of disease samples. Using these ML models},
  doi       = {10.1101/2020.12.06.413435},
  file      = {:Khatami2020 - Using Predictive Machine Learning Models for Drug Response Simulation by Calibrating Patient Specific Pathway Signatures.pdf:PDF},
  keywords  = {biological pathways, machine-learning, drug discovery, predictive models, knowledge graphs},
  publisher = {Cold Spring Harbor Laboratory},
}

@InProceedings{Kikinis2000,
  author    = {Kikinis, Ron and Mehta, Neerav and Nabavi, Arya and Chatzidakis, Emmanouel and Warfield, Simon and Gering, David and Weisenfeld, Neil and Pergolizzi, Richard and Schwartz, Richard and Hata, Nobuhiko and Wells, William and Grimson, Eric and Black, Peter and Jolesz, Ferenc},
