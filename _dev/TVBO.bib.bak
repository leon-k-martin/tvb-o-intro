@Article{Lawrence2021,
  author    = {Lawrence, Ross M. and Bridgeford, Eric W. and Myers, Patrick E. and Arvapalli, Ganesh C. and Ramachandran, Sandhya C. and Pisner, Derek A. and Frank, Paige F. and Lemmer, Allison D. and Nikolaidis, Aki and Vogelstein, Joshua T.},
  journal   = {Scientific Data},
  title     = {Standardizing human brain parcellations},
  year      = {2021},
  issn      = {2052-4463},
  month     = mar,
  number    = {1},
  volume    = {8},
  abstract  = {Using brain atlases to localize regions of interest is a requirement for making neuroscientifically valid statistical inferences. these atlases, represented in volumetric or surface coordinate spaces, can describe brain topology from a variety of perspectives. although many human brain atlases have circulated the field over the past fifty years, limited effort has been devoted to their standardization. Standardization can facilitate consistency and transparency with respect to orientation, resolution, labeling scheme, file storage format, and coordinate space designation. Our group has worked to consolidate an extensive selection of popular human brain atlases into a single, curated, open-source library, where they are stored following a standardized protocol with accompanying metadata, which can serve as the basis for future atlases. The repository containing the atlases, the specification, as well as relevant transformation functions is available in the neuroparc OSF registered repository or https:// github.com/neurodata/neuroparc.},
  doi       = {10.1038/s41597-021-00849-3},
  file      = {:Lawrence2021 - Standardizing Human Brain Parcellations.pdf:PDF:https\://www.nature.com/articles/s41597-021-00849-3.pdf},
  groups    = {Brain Atlas Ontology},
  publisher = {Springer Science and Business Media LLC},
}

