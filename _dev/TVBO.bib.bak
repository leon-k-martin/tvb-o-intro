@Article{Arora2023,
  author    = {Arora, Anmol and Alderman, Joseph E. and Palmer, Joanne and Ganapathi, Shaswath and Laws, Elinor and McCradden, Melissa D. and Oakden-Rayner, Lauren and Pfohl, Stephen R. and Ghassemi, Marzyeh and McKay, Francis and Treanor, Darren and Rostamzadeh, Negar and Mateen, Bilal and Gath, Jacqui and Adebajo, Adewole O. and Kuku, Stephanie and Matin, Rubeta and Heller, Katherine and Sapey, Elizabeth and Sebire, Neil J. and Cole-Lewis, Heather and Calvert, Melanie and Denniston, Alastair and Liu, Xiaoxuan},
