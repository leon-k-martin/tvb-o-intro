@Article{Thomas2019,
  author    = {Paul D. Thomas and David P. Hill and Huaiyu Mi and David Osumi-Sutherland and Kimberly Van Auken and Seth Carbon and James P. Balhoff and Laurent-Philippe Albou and Benjamin Good and Pascale Gaudet and Suzanna E. Lewis and Christopher J. Mungall},
  journal   = {Nature Genetics},
  title     = {Gene Ontology Causal Activity Modeling ({GO}-{CAM}) moves beyond {GO} annotations to structured descriptions of biological functions and systems},
  year      = {2019},
  month     = sep,
  number    = {10},
  pages     = {1429--1433},
