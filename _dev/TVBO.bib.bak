@Article{Escrichs2022,
  author    = {Escrichs, Anira and Sanz Perl, Yonatan and Martínez-Molina, Noelia and Biarnes, Carles and Garre-Olmo, Josep and Fernández-Real, José Manuel and Ramos, Rafel and Martí, Ruth and Pamplona, Reinald and Brugada, Ramon and Serena, Joaquin and Ramió-Torrentà, Lluís and Coll-De-Tuero, Gabriel and Gallart, Luís and Barretina, Jordi and Vilanova, Joan C and Mayneris-Perxachs, Jordi and Saba, Luca and Pedraza, Salvador and Kringelbach, Morten L and Puig, Josep and Deco, Gustavo},
