@Article{Mak2015,
  author    = {Mak, Elijah and Su, Li and Williams, Guy B. and Watson, Rosie and Firbank, Michael J. and Blamire, Andrew M. and O’Brien, John T.},
  journal   = {Neurobiology of Aging},
  title     = {Progressive cortical thinning and subcortical atrophy in dementia with Lewy bodies and Alzheimer’s disease},
  year      = {2015},
  issn      = {0197-4580},
  month     = apr,
  number    = {4},
  pages     = {1743--1750},
  volume    = {36},
  abstract  = {Patterns of progressive cortical thinning in dementia with Lewy bodies (DLB) remain poorly understood. We examined spatiotemporal patterns of cortical thinning and subcortical atrophy over 12 months in DLB (n ¼ 13), compared with Alzheimer's disease (AD) (n ¼ 23) and healthy control subjects (HC) (n ¼ 33). Rates of temporal thinning in DLB were relatively preserved compared with AD. Volumetric analyses subcortical changes revealed that the AD group demonstrated significantly increased hippocampal atrophy (À5.8%) relative to the HC (À1.7%; p < 0.001) and DLB groups (À2.5%, p ¼ 0.006). Significant lateral ventricular expansion was also observed in AD (8.9%) compared with HC (4.3%; p < 0.001) and DLB (4.7%; p ¼ 0.008) at trend level. There was no significant difference in subcortical atrophy and ventricular expansion between DLB and HC. In the DLB group, increased rates of cortical thinning in the frontal and parietal regions were significantly correlated with decline in global cognition (Mini-Mental State Examination) and motor deterioration (Unified Parkinson's Disease Rating Scale 3), respectively. Overall, AD and DLB are characterized by different spatiotemporal patterns of cortical thinning over time. Our findings warrant further consideration of longitudinal cortical thinning as a potential imaging marker to differentiate DLB from AD.},
  date      = {2015-01-08},
  day       = {8},
  doi       = {10.1016/j.neurobiolaging.2014.12.038},
  file      = {:Mak2015 - Progressive Cortical Thinning and Subcortical Atrophy in Dementia with Lewy Bodies and Alzheimer’s Disease.pdf:PDF},
  keywords  = {Dementia, Alzheimer's disease, Lewy bodies, MRI, Neuroimaging, Atrophy},
  publisher = {Elsevier BV},
}

