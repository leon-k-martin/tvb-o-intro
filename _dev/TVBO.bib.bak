@Article{Conte2020,
  author    = {Conte, Federica and Fiscon, Giulia and Licursi, Valerio and Bizzarri, Daniele and D’Antò, Tommaso and Farina, Lorenzo and Paci, Paola},
  journal   = {Biochimica et Biophysica Acta (BBA) - Gene Regulatory Mechanisms},
  title     = {A paradigm shift in medicine: A comprehensive review of network-based approaches},
  year      = {2020},
  issn      = {1874-9399},
  month     = jun,
  number    = {6},
  pages     = {194416},
  volume    = {1863},
  abstract  = {Network medicine is a rapidly evolving new field of medical research, which combines principles and approaches of systems biology and network science, holding the promise to uncovering the causes and to revolutionize the diagnosis and treatments of human diseases. This new paradigm reflects the fact that human diseases are not caused by single molecular defects, but driven by complex interactions among a variety of molecular mediators. The complexity of these interactions embraces different types of information: from the cellular-molecular level of protein-protein interactions to correlational studies of gene expression and regulation, to metabolic and disease pathways up to drug-disease relationships. The analysis of these complex networks can reveal new disease genes and/or disease pathways and identify possible targets for new drug development, as well as new uses for existing drugs. In this review, we offer a comprehensive overview of network types and algorithms used in the framework of network medicine.},
  doi       = {10.1016/j.bbagrm.2019.194416},
  file      = {:Conte2020 - A Paradigm Shift in Medicine_ a Comprehensive Review of Network Based Approaches.pdf:PDF},
  keywords  = {Network medicine, Precision medicine, Complex biological networks, Algorithms},
  publisher = {Elsevier BV},
}

