@Article{Joliot2015,
  author    = {Joliot, Marc and Jobard, Gaël and Naveau, Mikaël and Delcroix, Nicolas and Petit, Laurent and Zago, Laure and Crivello, Fabrice and Mellet, Emmanuel and Mazoyer, Bernard and Tzourio-Mazoyer, Nathalie},
  journal   = {Journal of Neuroscience Methods},
  title     = {AICHA: An atlas of intrinsic connectivity of homotopic areas},
  year      = {2015},
