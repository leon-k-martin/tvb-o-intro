  doi       = {10.1038/sdata.2016.18},
  file      = {:Wilkinson2016 - The FAIR Guiding Principles for Scientific Data Management and Stewardship.pdf:PDF:https\://www.nature.com/articles/sdata201618.pdf},
  groups    = {Reproducibility and data-sharing in Neuroscience, F.A.I.R.},
  publisher = {Springer Science and Business Media LLC},
}

@InProceedings{Williams0019,
  author   = {Williams, Kate and Barrett, Margaret and Graham, ; and Welch, F and Abad, Vicky and Broughton, Mary},
  title    = {Elsevier Editorial System(tm) for Early Childhood Research Quarterly Manuscript Draft},
  year     = {0019},
  abstract = {The benefits of early shared book reading between parents and children have long been established, yet the same cannot be said for early shared music activities in the home. This study investigated the parent-child home music activities in a sample of 3,031 Australian children participating in Growing Up in Australia: The Longitudinal Study of Australian Children (LSAC) study. Frequency of shared home music activities was reported by parents when children were 2-3 years and a range of social, emotional, and cognitive outcomes were measured by parent and teacher report and direct testing two years later when children were 4-5 years old. A series of regression analyses (controlling for a set of important socio-demographic variables) found frequency of shared home music activities to have a small significant partial association with measures of children's vocabulary, numeracy, attentional and emotional regulation, and prosocial skills. We then included both book reading and shared home music activities in the same models and found that frequency of shared home music activities maintained small partial associations with measures of prosocial skills, attentional regulation, and numeracy. Our findings suggest there may be a role for parent-child home music activities in supporting children's development. Highlights  First study to document evidence for the associations between early shared home music activities and later outcomes for children.  Higher frequency of shared book reading at 2-3 years associated with better vocabulary, numeracy, school readiness, attentional and emotional regulation, and prosocial skills, and fewer behavioral problems at 4-5 years.  Higher frequency of shared home music activities at 2-3 years maintained associations with later prosocial skills, numeracy, and attentional regulation when book reading included in the model.},
  file     = {:Williams0019 - Elsevier Editorial System(tm) for Early Childhood Research Quarterly Manuscript Draft.pdf:PDF},
  keywords = {early childhood, home learning environment, home music activities, shared music-making, shared book reading, self-regulation, literacy, numeracy, social skills, behavioral problems, vocabulary, school readiness},
}

